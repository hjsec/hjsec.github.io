---
import { Link, Notification } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'

interface Props {
  src?: string
}

const { src = '/astronaut-hero-img.webp' }: Props = Astro.props
---

<section class="hero my-24">
  <div class="container">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-24">
      <div class="flex flex-col items-center gap-6 md:items-start">
        <h1 class="text-center text-4xl md:text-6xl lg:text-8xl md:text-left">
          <span class="text-gradient">花江安全</span>
        </h1>
        <p class="text-center text-lg md:text-2xl md:text-left">
          桂林电子科技大学计算机与信息安全学院大学生科技协会--安全部。HJSec 意为花江安全，是我们的品牌名。
        </p>
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
          <Link
            href="/contact"
            isButton
            type="primary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="lucide:star" size="1.5rem" />
            招新通知
          </Link>
          <Link
            href="/about"
            isButton
            type="secondary"
            animateOnHover
            animationType="boop"
          >
            <Icon aria-hidden="true" name="lucide:bookmark" size="1.5rem" />
            关于我们
          </Link>
        </div>
      </div>
      <Image class="mx-auto w-3/4 lg:w-full" src={src} alt="" decoding="async" width={800} height={600} loading="eager" />
    </div>
  </div>
</section>

<style lang="scss" is:global>
  h1 {
    text-wrap: unset;
  }

  /* 强制彩色渐变，任何情况下都不被覆盖 */
  .text-gradient {
    background: linear-gradient(
      315deg,
      #63b3ed 25%,
      #b794f4 100%
    ) !important;
    -webkit-background-clip: text !important;
    background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
  }
</style>
