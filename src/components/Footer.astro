---
import { Heading } from 'accessible-astro-components'
---

<footer class="mt-24 py-12" style="
  background: linear-gradient(0deg, rgba(245,248,255,0.6) 0%, rgba(255,255,255,0) 100%);
  border-top: 2px solid transparent;
  border-image: linear-gradient(90deg, #63b3ed, #b794f4) 1;
">
  <div class="container">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- 1. 社团信息 -->
      <div class="space-content">
        <Heading level="h3" class="!mb-3 !text-lg !font-semibold">花江安全局</Heading>
        <p class="text-sm opacity-80">
          桂林电子科技大学计算机与信息安全学院大学生科技协会下属安全方向团队。
        </p>
        <p class="text-sm mt-2 opacity-70 italic">
          在二进制中寻找漏洞，在数字世界里找到我们。
        </p>
      </div>

      <!-- 2. 快速链接 -->
      <div class="space-content">
        <Heading level="h3" class="!mb-3 !text-lg !font-semibold">快速链接</Heading>
        <ul class="list-none space-y-2">
          <li><a href="/" class="text-sm hover:underline" style="transition: color 0.2s;">首页</a></li>
          <li><a href="/about" class="text-sm hover:underline" style="transition: color 0.2s;">关于我们</a></li>
          <li><a href="/portfolio" class="text-sm hover:underline" style="transition: color 0.2s;">成员</a></li>
          <li><a href="/contact" class="text-sm hover:underline" style="transition: color 0.2s;">加入我们</a></li>
        </ul>
      </div>

      <!-- 3. 友情链接 -->
      <div class="space-content">
        <Heading level="h3" class="!mb-3 !text-lg !font-semibold">友情链接</Heading>
        <ul class="list-none space-y-2">
          <li>
            <a href="https://todaymvp.github.io" target="_blank" rel="noopener noreferrer" class="text-sm hover:underline" style="transition: color 0.2s;">
              步六孤的博客
            </a>
          </li>
          <li>
            <a href="https://ctf-wiki.org/" target="_blank" rel="noopener noreferrer" class="text-sm hover:underline" style="transition: color 0.2s;">
              CTF Wiki
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- 底部版权栏 -->
    <div class="mt-12 pt-6 text-center text-sm" style="border-top: 1px solid rgba(99,179,237,0.15);">
      <p class="opacity-80">© 2026 花江安全局. Created by 步六孤.</p>
      <p class="mt-2 opacity-50 text-xs">
        Tip: always test for screen reader support. Press ⌘ + F5 to start VoiceOver or Win + Ctrl + Enter for Narrator.
      </p>
    </div>
  </div>
</footer>

<style lang="scss" is:global>
  footer {
    a {
      color: var(--foreground-color);
      opacity: 0.75;
      transition: color 0.2s, opacity 0.2s;
    }
    a:hover {
      opacity: 1;
      color: #63b3ed;
    }
  }
</style>
