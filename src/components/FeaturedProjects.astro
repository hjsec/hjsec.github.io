---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'

const projects = await getCollection('projects')
const featuredProjects = projects.slice(0, 4)
---

<section class="mb-24">
  <div class="container">
    <h2 class="mb-12 text-center text-3xl font-bold">核心成员</h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {featuredProjects.map(project => {
        const slug = project.id || project.slug
        return (
          <a href={`/portfolio/${slug}`} class="group flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 text-center no-underline shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
            <img
              src={project.data.image}
              alt={project.data.title}
              class="mb-4 h-24 w-24 rounded-full border-2 border-[var(--border-color-subtle)] object-cover"
              loading="lazy"
            />
            <h3 class="mb-1 text-xl font-bold text-[var(--foreground-color)]">{project.data.title}</h3>
            <p class="mb-2 text-sm text-[var(--foreground-color)] opacity-80">{project.data.description}</p>
            {project.data.motto && (
              <>
                <blockquote class="member-motto">
                  “{project.data.motto}”
                </blockquote>
                <hr class="my-2 w-3/5 border-t border-[var(--border-color-subtle)]" />
              </>
            )}
            {project.data.links?.length > 0 && (
              <div class="flex flex-wrap justify-center gap-2 mt-2">
                {project.data.links.map(link => {
                  const [key, value] = Object.entries(link)[0];
                  return (
                    <a
                      href={value}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="rounded-full border border-[var(--border-color-subtle)] px-3 py-1 text-xs font-medium text-[var(--foreground-color)] no-underline transition hover:bg-[var(--color-primary)] hover:text-white"
                    >
                      {key}
                    </a>
                  );
                })}
              </div>
            )}
          </a>
        )
      })}
    </div>
    <div class="mt-8 text-center">
      <a href="/portfolio" class="inline-block rounded-full bg-[var(--color-primary)] px-6 py-3 text-white no-underline hover:opacity-90">
        查看全部成员
      </a>
    </div>
  </div>
</section>
