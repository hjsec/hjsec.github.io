---
import DefaultLayout from '@layouts/DefaultLayout.astro'

const { frontmatter } = Astro.props
---

<DefaultLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="narrow container my-12">
    <h1 class="mb-6 text-4xl font-bold">{frontmatter.title}</h1>
    <div class="prose max-w-none">
      <slot />
    </div>
    <nav class="mt-12 flex justify-between border-t border-[var(--border-color-subtle)] pt-6">
      {frontmatter.prev ? <a href={frontmatter.prev} class="text-[var(--color-primary)] no-underline hover:underline">&larr; 上一页</a> : <span />}
      {frontmatter.next ? <a href={frontmatter.next} class="text-[var(--color-primary)] no-underline hover:underline">下一页 &rarr;</a> : <span />}
    </nav>
  </article>
</DefaultLayout>

<style>
  .narrow {
    max-width: 65ch;
    margin-inline: auto;
  }
</style>
