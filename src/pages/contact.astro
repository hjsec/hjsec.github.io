---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
---

<DefaultLayout class="contact-page" title="加入我们">
  <PageHeader
    title="加入我们"
    subtitle="在二进制中寻找漏洞，在数字世界里找到我们。"
    bgType="gradient"
  />
  <section class="container my-16">
    <div class="grid grid-cols-1 gap-16 md:grid-cols-2">
      <!-- 左栏：社团简介 + 招新信息 + 招新历程 -->
      <div class="space-content">
        <p class="text-lg mb-6">
          <strong>花江安全</strong>（Huajiang Security，HJSec）隶属于桂林电子科技大学计算机与信息安全学院大学生科技协会，为科协安全部，欢迎每一个对安全有热情的同学。
        </p>

        <div class="rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 shadow-sm mb-8">
          <h2 class="text-xl font-bold mb-4 flex items-center gap-2">
            <span>📋</span> 招新信息
          </h2>
          <ul class="list-inside list-disc my-4 space-y-3">
            <li><strong>面向对象</strong>：全校在校生，不限专业，热烈欢迎大一新生</li>
            <li><strong>基本要求</strong>：对信息安全有浓厚兴趣，具备或愿意学习网络安全有关知识</li>
            <li><strong>方向选择</strong>：二进制安全 (Pwn)、逆向工程 (Reverse)、Web 安全、密码学 (Crypto)、MISC</li>
          </ul>
        </div>

        <div class="rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 shadow-sm">
          <h2 class="text-xl font-bold mb-6 flex items-center gap-2">
            <span>🗺️</span> 招新历程
          </h2>
          <div class="space-y-4">
            <div>
              <h3 class="font-bold">① 迎新赛：8月（入学前）</h3>
              <p class="opacity-80 text-sm">在家打迎新靶场，了解 CTF 基础。</p>
            </div>
            <div>
              <h3 class="font-bold">② 招新赛：9月（开学后）</h3>
              <p class="opacity-80 text-sm">通过题目考察成员，靶场持续开放，可随时请教。</p>
            </div>
            <div>
              <h3 class="font-bold">③ 面试：10月底</h3>
              <p class="opacity-80 text-sm">双向选择，正式加入花江安全。</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 右栏：靶场入口 + 加入方式 -->
      <div class="space-content">
        <!-- 靶场 -->
        <div class="rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 shadow-sm mb-8 text-center">
          <h2 class="text-xl font-bold mb-4 flex items-center justify-center gap-2">
            <span>🎯</span> 迎新靶场
          </h2>
          <div class="space-y-3">
            <div>
              <p class="text-sm font-semibold mb-1">🏫 校园网（快速）</p>
              <a href="http://125.217.52.145/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] font-semibold hover:underline">http://125.217.52.145/\</a\>
            </div>
            <div>
              <p class="text-sm font-semibold mb-1">🌐 公网</p>
              <a href="http://sayble.xyz:18080/" target="_blank" rel="noopener noreferrer" class="text-[var(--color-primary)] font-semibold hover:underline">http://sayble.xyz:18080/\</a\>
            </div>
          </div>
          <p class="text-sm opacity-70 mt-4">校内同学请尽量用校园网，速度更快。</p>
        </div>

        <!-- 加入方式 -->
        <div class="rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 shadow-sm text-center">
          <h2 class="text-xl font-bold mb-4 flex items-center justify-center gap-2">
            <span>📬</span> 加入方式
          </h2>
          <div class="bg-[rgba(99,179,237,0.1)] rounded-xl p-6 mb-4">
            <p class="text-lg mb-2">招新 QQ 群</p>
            <p class="text-4xl font-extrabold text-[var(--color-primary)] mb-3">995962963</p>
            <a href="https://qm.qq.com/q/5pvaUJFYXu" target="_blank" rel="noopener noreferrer" class="inline-block rounded-full bg-[var(--color-primary)] px-6 py-2.5 text-white font-semibold no-underline hover:opacity-90 transition shadow-md">
              点击加入群聊
            </a>
          </div>
          <div class="mt-4">
            <img src="/img/recruitment.png" alt="招新群二维码" class="mx-auto w-48 h-auto rounded-xl shadow-md" loading="lazy" />
            <p class="text-sm opacity-70 mt-2">扫码加入 26级三院科协安全部招新群</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
