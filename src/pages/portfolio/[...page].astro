---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Card, Pagination } from 'accessible-astro-components'
import { getCollection } from 'astro:content'

export async function getStaticPaths({ paginate }) {
  const projects = await getCollection('projects')
  return paginate(projects, { pageSize: 8 })
}

const { page } = Astro.props
---

<DefaultLayout title="成员 | 花江安全局">
  <PageHeader
    title="成员"
    subtitle="花江安全局核心成员"
    bgType="gradient"
  />
  <section class="my-12">
    <div class="container">
      <p class="text-sm mb-6"><em>共 {page.total} 位成员，当前第 {page.currentPage} 页</em></p>
      {page.data.length > 0 ? (
        <div>
          {Object.entries(
            page.data.reduce((acc, project) => {
              const grade = project.data.tags?.find(tag => tag.endsWith('级')) || '其他'
              if (!acc[grade]) acc[grade] = []
              acc[grade].push(project)
              return acc
            }, {})
          )
            .sort(([a], [b]) => {
              const numA = parseInt(a) || 0
              const numB = parseInt(b) || 0
              return numB - numA
            })
            .map(([grade, projectsInGrade]) => (
              <div class="mb-12">
                <h2 class="text-2xl font-bold mb-6 border-b pb-2 border-[var(--border-color-subtle)]">{grade}</h2>
                <ul class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
                  {projectsInGrade.map(project => {
                    const slug = project.id || project.slug
                    return (
                      <li>
                        <div class="card group flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 text-center no-underline shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
                          <a href={`/portfolio/${slug}`} class="flex flex-col items-center no-underline">
                            <img
                              src={project.data.image}
                              alt={project.data.title}
                              class="mb-4 h-24 w-24 rounded-full border-2 border-[var(--border-color-subtle)] object-cover"
                              loading="lazy"
                            />
                            <h3 class="mb-1 text-xl font-bold text-[var(--foreground-color)]">{project.data.title}</h3>
                            <p class="mb-2 text-sm text-[var(--foreground-color)] opacity-80">{project.data.description}</p>
                            {project.data.motto && (
                              <>
                                <blockquote class="member-motto">
                                  “{project.data.motto}”
                                </blockquote>
                                <hr class="my-2 w-3/5 border-t border-[var(--border-color-subtle)]" />
                              </>
                            )}
                          </a>
                          {project.data.links?.length > 0 && (
                            <div class="flex flex-wrap justify-center gap-2 mt-2">
                              {project.data.links.map(link => {
                                const [key, value] = Object.entries(link)[0];
                                return (
                                  <a
                                    href={value}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="rounded-full border border-[var(--border-color-subtle)] px-3 py-1 text-xs font-medium text-[var(--foreground-color)] no-underline transition hover:bg-[var(--color-primary)] hover:text-white"
                                  >
                                    {key}
                                  </a>
                                );
                              })}
                            </div>
                          )}
                        </div>
                      </li>
                    )
                  })}
                </ul>
              </div>
            ))
          }
        </div>
      ) : (
        <p>暂无成员</p>
      )}
      {page.lastPage > 1 && (
        <div class="mt-12 grid place-content-center">
          <Pagination
            firstPage={page.url.prev ? '/portfolio' : null}
            previousPage={page.url.prev ?? null}
            nextPage={page.url.next ?? null}
            lastPage={page.url.next ? `/portfolio/${page.lastPage}` : null}
            currentPage={`${page.currentPage}`}
            totalPages={`${page.lastPage}`}
            ariaLabel="成员分页"
          />
        </div>
      )}
    </div>
  </section>
</DefaultLayout>
