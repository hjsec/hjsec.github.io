---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  const perPage = 8
  const totalPages = Math.ceil(projects.length / perPage)
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: i === 0 ? undefined : String(i + 1) },
    props: { projects, page: i + 1, totalPages }
  }))
}

const { projects, page = 1, totalPages = 1 } = Astro.props
const perPage = 8
const start = (page - 1) * perPage
const pagedProjects = projects.slice(start, start + perPage)
---

<DefaultLayout title="成员 | 花江安全局">
  <PageHeader title="成员" description="花江安全局核心成员" />
  <div class="container grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {pagedProjects.map(project => (
      <a href={`/portfolio/${project.id}`} class="group flex flex-col items-center rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 text-center no-underline shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <img
          src={project.data.image}
          alt={project.data.title}
          class="mb-4 h-24 w-24 rounded-full border-2 border-[var(--border-color-subtle)] object-cover"
          loading="lazy"
        />
        <h3 class="mb-1 text-xl font-bold text-[var(--foreground-color)]">{project.data.title}</h3>
        <p class="mb-2 text-sm text-[var(--foreground-color)] opacity-80">{project.data.description}</p>
        {project.data.motto && (
          <blockquote class="mb-4 text-sm italic text-[var(--foreground-color)] opacity-60">
            “{project.data.motto}”
          </blockquote>
        )}
        {project.data.links?.length > 0 && (
          <>
            <hr class="my-4 w-3/5 border-t border-[var(--border-color-subtle)]" />
            <div class="flex flex-wrap justify-center gap-2">
              {project.data.links.map(link => {
                const [key, value] = Object.entries(link)[0];
                return (
                  <span class="rounded-full border border-[var(--border-color-subtle)] px-3 py-1 text-xs font-medium text-[var(--foreground-color)] transition hover:bg-[var(--color-primary)] hover:text-white">
                    {key}
                  </span>
                );
              })}
            </div>
          </>
        )}
      </a>
    ))}
  </div>
  {totalPages > 1 && (
    <nav class="mt-12 flex justify-center gap-4">
      {page > 1 && <a href={`/portfolio${page > 2 ? `/${page - 1}` : ''}`} class="rounded-full border px-4 py-2">上一页</a>}
      {Array.from({ length: totalPages }, (_, i) => (
        <a href={`/portfolio${i === 0 ? '' : `/${i + 1}`}`} class={`rounded-full px-4 py-2 ${page === i + 1 ? 'bg-[var(--color-primary)] text-white' : 'border'}`}>
          {i + 1}
        </a>
      ))}
      {page < totalPages && <a href={`/portfolio/${page + 1}`} class="rounded-full border px-4 py-2">下一页</a>}
    </nav>
  )}
</DefaultLayout>
