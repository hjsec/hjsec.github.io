---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Hero from '@components/Hero.astro'
---

<DefaultLayout title="花江安全局" useTitleTemplate={false}>
  <Hero />

  <!-- 宣传图片展示（我们的身影） -->
  <section class="mb-24">
    <div class="container">
      <h2 class="text-center text-3xl font-bold mb-12">我们的身影</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6">
        <div class="rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
          <img src="/img/xuanchuan.jpg" alt="社团宣传" class="w-full h-60 object-cover" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
          <img src="/img/door.jpg" alt="社团门口" class="w-full h-60 object-cover" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
          <img src="/img/inside.jpg" alt="社团内部" class="w-full h-60 object-cover" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow duration-300">
          <img src="/img/total.jpg" alt="社团合影" class="w-full h-60 object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

