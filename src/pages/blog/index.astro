---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
---

<DefaultLayout title="知识库 | 花江安全局" description="了解CTF和安全方向的入门知识">
  <PageHeader
    title="知识库"
    subtitle="从这里开始你的信息安全之旅"
    bgType="bordered"
  />

  <section class="my-12">
    <div class="container grid gap-6 md:grid-cols-3">
      <a href="/blog/what-is-ctf" class="group rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 no-underline shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <h2 class="mb-3 text-2xl font-bold text-[var(--foreground-color)]">什么是 CTF？</h2>
        <p class="text-[var(--foreground-color)] opacity-80">CTF（夺旗赛）是信息安全竞赛的简称，了解它的基本模式和魅力。</p>
      </a>
      <a href="/blog/security-fields" class="group rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 no-underline shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <h2 class="mb-3 text-2xl font-bold text-[var(--foreground-color)]">安全方向简介</h2>
        <p class="text-[var(--foreground-color)] opacity-80">Web、Pwn、Reverse、Crypto…… 找到你感兴趣的方向。</p>
      </a>
      <a href="/blog/learning-path" class="group rounded-xl border border-[var(--border-color-subtle)] bg-[var(--background-color)] p-6 no-underline shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
        <h2 class="mb-3 text-2xl font-bold text-[var(--foreground-color)]">学习路线</h2>
        <p class="text-[var(--foreground-color)] opacity-80">从零开始，一步步成为安全高手。</p>
      </a>
    </div>
  </section>
</DefaultLayout>
